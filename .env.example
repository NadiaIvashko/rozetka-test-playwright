# Скопіюй цей файл як .env та підстав реальні значення.
# .env у .gitignore — НЕ комітити креди!

# Тестовий акаунт Rozetka
ROZETKA_USER_EMAIL=your_email@example.com
ROZETKA_USER_PASSWORD=your_password

# Опційно: окремий URL якщо потрібно перевизначити (за замовчуванням з playwright.config.ts)
# BASE_URL=https://rozetka.com.ua/
